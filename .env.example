# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Google ────────────────────────────────────────────────────────────────────
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SLIDES_PRESENTATION_ID=

# ── OpenAI / LLM ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Minimax ──────────────────────────────────────────────────────────────────
# Minimax Plan for OpenCode
MINIMAX_API_KEY=
# MINIMAX_MODEL=minimax-coding-plan/MiniMax-M2.5

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram Chat ID (for sending messages TO you)
# Used by: tools/tldr/tldr_digest_notifier.py
# Get from @userinfobot or @myidbot
TELEGRAM_CHAT_ID=

# Allowed Telegram User ID (for receiving commands FROM users)
# Used by: tools/telegram/bridge.py, tools/repo/sentinel.py
# Optional but recommended to prevent unauthorized access
# Get from @userinfobot or @myidbot
TELEGRAM_ALLOWED_USER_ID=

# ── Groq (Audio Transcription) ────────────────────────────────────────────────
# Get from console.groq.com (for audio transcription)
GROQ_API_KEY=

# ── SEARXNG (Self-hosted metasearch) ────────────────────────────────────────
# Your SEARXNG instance URL (leave empty to skip)
SEARXNG_URL=

# ── Search Configuration ──────────────────────────────────────────────────────
# Search timeout in seconds (default: 10)
# SEARCH_TIMEOUT=10

# ── Add more keys below as new tools require them ────────────────────────────
