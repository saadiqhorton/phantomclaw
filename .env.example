# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Google ────────────────────────────────────────────────────────────────────
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SLIDES_PRESENTATION_ID=

# ── OpenAI / LLM ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Telegram Bridge ──────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Get from console.groq.com (for audio transcription)
GROQ_API_KEY=

# Minimax Plan for OpenCode
MINIMAX_API_KEY=
# MINIMAX_MODEL=minimax-coding-plan/MiniMax-M2.5
# TELEGRAM_ALLOWED_USER_ID=

# ── Add more keys below as new tools require them ────────────────────────────
